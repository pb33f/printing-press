{
  "name": "@pb33f/printing-press",
  "version": "0.0.0",
  "description": "Installable npm wrapper for the pb33f printing-press CLI",
  "type": "module",
  "author": "pb33f",
  "license": "UNLICENSED",
  "homepage": "https://github.com/pb33f/printing-press#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pb33f/printing-press.git"
  },
  "bugs": {
